# ============================================================
# ai-diary — .gitignore
# 以下全部屬於個人私密資料，絕對不進 repo
# ============================================================

# 日記本體（個人記憶，不開源）
diary/20*/
diary/summaries/

# 自我敘事（個人身份）
diary/self-narrative.md

# 未鞏固事件紀錄
diary/raw_buffer.jsonl
diary/buffer.jsonl
diary/buffer.json
# consolidate 鞏固期間的原子快照（batch-<timestamp>.jsonl，敏感度同 raw_buffer）
diary/batch-*.jsonl

# ROI 索引（含日記摘要）
diary/index/

# Python cache
src/__pycache__/
*.pyc
*.pyo
.DS_Store

# 如果有人在本地測試時建立的臨時檔案
*.tmp
*.bak

# 原始 buffer 備份（最敏感，務必忽略）
diary/archive/
# L2 scenario 檔（含個人記憶衍生內容）
diary/scenarios/
# 本地模型快取（~120MB，且 README 宣稱已 ignore）
models/

# Obsidian vault 個人設定（非引擎資料，純本地 UI 狀態）
.obsidian/
